cat << 'EOF' > test-kernel.asm
BITS 64
SECTION .text
global _start

_start:
    ; El stack no es estrictamente necesario para este hola mundo, 
    ; pero es buena práctica en Ring 0.
    mov rsi, message
    mov rcx, message_len
.loop:
    lodsb               ; Carga byte de [RSI] en AL y RSI++
    out 0x3F8, al       ; Envía al puerto COM1
    loop .loop
    hlt                 ; VMEXIT de tipo Hlt para cerrar la vCPU

SECTION .rodata
message: db "¡Hola NKR! Estamos corriendo en Ring 0 sobre Google Cloud.", 10
message_len equ $ - message
EOF